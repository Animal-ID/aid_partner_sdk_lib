{
  "name": "aid-partner-sdk",
  "version": "0.2.0",
  "private": true,
  "description": "Animal-ID Partner API SDK — isomorphic core + thin framework adapters (React, Vue, Angular, NestJS).",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" run dev",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "clean": "pnpm -r run clean",
    "lint": "pnpm -r --filter \"./packages/*\" run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  }
}
